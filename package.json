{
	"name": "zurichjs-conf",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
	"engines": {
		"node": ">=22 <23",
		"pnpm": "11.x"
	},
	"scripts": {
		"preinstall": "scripts/require-docker-or-ci.sh",
		"dev": "scripts/require-docker-or-ci.sh && next dev",
		"dev:docker": "scripts/docker-dev.sh",
		"docker:up": "scripts/docker-dev.sh",
		"docker:dev": "scripts/docker-dev.sh",
		"docker:down": "scripts/docker-down.sh",
		"varlock:check": "scripts/require-docker-or-ci.sh && varlock load",
		"build": "scripts/require-docker-or-ci.sh && next build",
		"build:clean": "scripts/require-docker-or-ci.sh && rm -rf .next && rm -rf node_modules/.cache && next build",
		"start": "scripts/require-docker-or-ci.sh && next start",
		"lint": "scripts/require-docker-or-ci.sh && oxlint --fix",
		"typecheck": "scripts/require-docker-or-ci.sh && tsc --noEmit",
		"clean": "scripts/require-docker-or-ci.sh && rm -rf .next && rm -rf node_modules/.cache",
		"email:dev": "scripts/require-docker-or-ci.sh && email dev --dir ./src/emails --port 3001",
		"test": "scripts/require-docker-or-ci.sh && vitest",
		"test:run": "scripts/require-docker-or-ci.sh && vitest run",
		"test:coverage": "scripts/require-docker-or-ci.sh && vitest run --coverage",
		"test:related": "scripts/require-docker-or-ci.sh && vitest related --run",
		"db:seed:cfp-first-stage": "scripts/seed-supabase-phase.sh cfp-first-stage",
		"db:seed:cfp-admission": "scripts/seed-supabase-phase.sh cfp-admission",
		"db:seed:cfp-schedule": "scripts/seed-supabase-phase.sh cfp-schedule",
		"db:seed:workshop-commerce": "scripts/seed-supabase-phase.sh workshop-commerce"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": "just lint-staged-check"
	},
	"dependencies": {
		"@headlessui/react": "^2.2.10",
		"@hookform/resolvers": "^5.2.2",
		"@nwpr/airport-codes": "^3.0.3",
		"@react-email/components": "^0.5.7",
		"@react-email/render": "^1.4.0",
		"@react-pdf/renderer": "^4.5.1",
		"@sentry/nextjs": "^10.51.0",
		"@stripe/react-stripe-js": "^6.3.0",
		"@stripe/stripe-js": "^9.4.0",
		"@supabase/ssr": "^0.7.0",
		"@supabase/supabase-js": "^2.105.1",
		"@tailwindcss/oxide": "^4.2.4",
		"@tanstack/react-query": "^5.100.6",
		"@types/qrcode": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cookie": "^1.1.1",
		"countries-list": "^3.3.0",
		"formidable": "^3.5.4",
		"framer-motion": "^12.38.0",
		"gray-matter": "^4.0.3",
		"ics": "^3.12.0",
		"lightningcss": "^1.32.0",
		"lucide-react": "^0.553.0",
		"lz-string": "^1.5.0",
		"micro": "^10.0.1",
		"next": "^16.2.4",
		"next-mdx-remote": "^6.0.0",
		"nuqs": "^2.8.9",
		"posthog-js": "^1.372.5",
		"posthog-node": "^5.32.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.74.0",
		"react-markdown": "^10.1.0",
		"recharts": "^3.8.1",
		"resend": "^6.12.2",
		"stripe": "^19.3.0",
		"styled-jsx": "5.1.6",
		"swiper": "^12.1.4",
		"tailwind-merge": "^3.5.0",
		"use-local-storage-state": "^19.5.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.4.1"
	},
	"pnpm": {
		"overrides": {
			"next>@next/env": "npm:@varlock/nextjs-integration@1.1.0",
			"resend>svix": "1.92.2"
		}
	},
	"devDependencies": {
		"@react-email/preview-server": "^5.2.10",
		"@tailwindcss/postcss": "^4.2.4",
		"@tanstack/react-query-devtools": "^5.100.6",
		"@types/cookie": "^1.0.0",
		"@types/formidable": "^3.5.1",
		"@types/mdx": "^2.0.13",
		"@types/micro": "^10.0.0",
		"@types/node": "^20.19.39",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/recharts": "^1.8.29",
		"@varlock/nextjs-integration": "1.1.0",
		"@vitest/coverage-v8": "^4.1.5",
		"oxlint": "^1.62.0",
		"react-email": "^5.2.11",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"varlock": "1.2.0",
		"vitest": "^4.1.5"
	}
}
